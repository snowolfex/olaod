{
  "name": "oload",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "broker:dev": "npm --prefix broker run dev",
    "broker:start": "npm --prefix broker run start",
    "build": "next build",
    "bundle:installers": "npm run build && node scripts/prepare-installer-bundles.mjs",
    "bundle:updates": "npm run bundle:installers && node scripts/prepare-update-packages.mjs",
    "package:installers": "npm run bundle:installers && node scripts/build-native-installers.mjs",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint",
    "test:e2e:server": "next start --hostname 127.0.0.1 --port 3101",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "google-auth-library": "^10.6.2",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
